{
  "sim": "xplane",
  "version": "12",
  "description": "X-Plane 12 dataref table — axis write paths, command refs",
  "variables": {
    "aileron": {
      "sim_var_name": "sim/joystick/yoke_roll_ratio",
      "unit": "ratio",
      "data_type": "float32",
