      "min": 0.0,
      "max": 1.0,
      "description": "Engine 1 mixture ratio"
    },
    "flaps": {
      "sim_var_name": "sim/cockpit2/controls/flap_ratio",
      "unit": "ratio",
      "data_type": "float32",
      "settable": true,
      "min": 0.0,
      "max": 1.0,
      "description": "Flap deployment ratio"
    },
    "gear": {
      "sim_var_name": "sim/cockpit/switches/gear_handle_status",
