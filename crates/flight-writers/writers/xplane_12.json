      "min": -1.0,
      "max": 1.0,
      "description": "Yoke roll ratio, -1 full left to +1 full right"
    },
    "elevator": {
      "sim_var_name": "sim/joystick/yoke_pitch_ratio",
      "unit": "ratio",
      "data_type": "float32",
      "settable": true,
      "min": -1.0,
      "max": 1.0,
      "description": "Yoke pitch ratio, -1 full down to +1 full up"
    },
    "rudder": {
      "sim_var_name": "sim/joystick/yoke_heading_ratio",
      "unit": "ratio",
      "data_type": "float32",
      "settable": true,
      "min": -1.0,
      "max": 1.0,
      "description": "Yoke heading (rudder) ratio"
    },
    "throttle": {
      "sim_var_name": "sim/cockpit2/engine/actuators/throttle_ratio[0]",
      "unit": "ratio",
