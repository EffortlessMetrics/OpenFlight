#!/bin/sh
# postrm script for flight-hub
#
# See: https://www.debian.org/doc/debian-policy/ch-maintainerscripts.html

set -e

UDEV_RULES_DST="/etc/udev/rules.d/99-flight-hub.rules"
CONFIG_DIR="/etc/flight-hub"
DATA_DIR="/var/lib/flightd"

case "$1" in
    remove)
        # Remove udev rules on package removal
        if [ -f "$UDEV_RULES_DST" ]; then
            rm -f "$UDEV_RULES_DST"
        fi

        # Reload udev rules
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules || true
            udevadm trigger || true
        fi
        ;;

    purge)
        # Remove udev rules if still present
        if [ -f "$UDEV_RULES_DST" ]; then
            rm -f "$UDEV_RULES_DST"
        fi

        # Reload udev rules
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules || true
            udevadm trigger || true
        fi

        # Remove system configuration directory if it exists
        if [ -d "$CONFIG_DIR" ]; then
            rm -rf "$CONFIG_DIR"
        fi

        # Remove system data directory if it exists
        if [ -d "$DATA_DIR" ]; then
            rm -rf "$DATA_DIR"
        fi

        echo ""
        echo "Flight Hub has been completely removed."
        echo ""
        echo "Note: User configuration in ~/.config/flight-hub/ and"
        echo "      user data in ~/.local/share/flight-hub/ were preserved."
        echo "      Remove these directories manually if desired."
        echo ""
        echo "To stop the user service before removal, users should run:"
        echo "  systemctl --user stop flightd.service"
        echo "  systemctl --user disable flightd.service"
        echo ""
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
