# Flight Hub udev rules
# Grants members of the 'input' group access to flight simulation HID devices
#
# These rules allow users in the 'input' group to access HID devices
# without requiring root privileges.
#
# To apply changes manually:
#   sudo udevadm control --reload-rules && sudo udevadm trigger

# ============================================================================
# Generic HID devices
# ============================================================================
# Allow input group access to all hidraw devices
SUBSYSTEM=="hidraw", MODE="0660", GROUP="input"

# Allow input group access to USB HID devices
SUBSYSTEM=="usb", ATTR{bInterfaceClass}=="03", MODE="0660", GROUP="input"

# ============================================================================
# Saitek / Logitech Flight (Vendor ID: 06a3)
# X52, X52 Pro, X55, X56, Pro Flight panels, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="06a3", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="06a3", MODE="0660", GROUP="input"

# ============================================================================
# Thrustmaster (Vendor ID: 044f)
# HOTAS Warthog, T.16000M, TCA Sidestick/Throttle, TWCS, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="044f", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="044f", MODE="0660", GROUP="input"

# ============================================================================
# Logitech General (Vendor ID: 046d)
# Extreme 3D Pro, G940, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="046d", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="046d", MODE="0660", GROUP="input"

# ============================================================================
# VKB (Vendor ID: 231d)
# Gladiator NXT, Gunfighter, STECS, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="231d", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="231d", MODE="0660", GROUP="input"

# ============================================================================
# Virpil (Vendor ID: 3344)
# Alpha, Constellation, CM2/CM3, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3344", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="3344", MODE="0660", GROUP="input"

# ============================================================================
# Winwing (Vendor ID: 4098)
# Orion, F-16EX, F/A-18, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="4098", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="4098", MODE="0660", GROUP="input"

# ============================================================================
# CH Products (Vendor ID: 068e)
# Pro Throttle, Fighterstick, Pro Pedals, etc.
# ============================================================================
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="068e", MODE="0660", GROUP="input"
SUBSYSTEM=="usb", ATTRS{idVendor}=="068e", MODE="0660", GROUP="input"
