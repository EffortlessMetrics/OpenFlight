<?xml version="1.0" encoding="UTF-8"?>
<!--
  Flight Hub Windows Installer - Main WiX Source (WiX 3.x)

  This installer creates an MSI package for Flight Hub with the following features:
  - Core: Required Flight Hub daemon and configuration (Level 1 - required)
  - CLI: Flight Hub command-line tools (Level 2 - optional, default selected)
  - PathEnv: Add to user PATH (Level 2 - optional, default selected)
  - MSFS: Microsoft Flight Simulator integration (Level 1000 - optional, not default)
  - XPlane: X-Plane plugin integration (Level 1000 - optional, not default)
  - DCS: DCS World Export.lua integration (Level 1000 - optional, not default)

  Install location: %LOCALAPPDATA%\FlightHub\ (per-user, no admin required)

  Requirements:
  - WiX Toolset 3.x
  - Windows SDK for signing
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <?define ProductName = "Flight Hub" ?>
  <?define Manufacturer = "OpenFlight" ?>
  <!-- Version passed via candle -dVersion=x.y.z -->
  <?define ProductVersion = "$(var.Version)" ?>
  <!-- Stable UpgradeCode - DO NOT CHANGE for upgrade compatibility -->
  <?define UpgradeCode = "8A7B6C5D-4E3F-2A1B-9C8D-7E6F5A4B3C2D" ?>

  <Product Id="*"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.ProductVersion)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">

    <!-- Per-user installation: no admin rights required -->
    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perUser"
             Description="$(var.ProductName) - Flight Simulation Input Management"
             Manufacturer="$(var.Manufacturer)"
             Comments="Flight Hub provides unified control for flight controls, panels, and force feedback devices." />

    <!-- Embed cabinet for single-file MSI -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- ========================================
         UPGRADE HANDLING
         ======================================== -->

    <!-- Major upgrade - removes previous versions -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of $(var.ProductName) is already installed. Please uninstall it first."
                  Schedule="afterInstallInitialize" />

    <!-- ========================================
         PROPERTIES
         ======================================== -->

    <!-- Default installation directory -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <!-- Add/Remove Programs metadata -->
    <Property Id="ARPPRODUCTICON" Value="FlightHubIcon.exe" />
    <Property Id="ARPURLINFOABOUT" Value="https://flight-hub.dev" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/EffortlessMetrics/OpenFlight/releases" />
    <Property Id="ARPHELPLINK" Value="https://github.com/EffortlessMetrics/OpenFlight/discussions" />

    <!-- ========================================
         CONDITIONS
         ======================================== -->

    <!-- Require Windows 10 or later -->
    <Condition Message="$(var.ProductName) requires Windows 10 or later.">
      <![CDATA[Installed OR VersionNT >= 603]]>
    </Condition>

    <!-- ========================================
         UI CONFIGURATION
         ======================================== -->

    <!-- License and UI images -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />

    <!-- Use WixUI_InstallDir for simple directory selection -->
    <UIRef Id="WixUI_InstallDir" />

    <!-- Custom error/warning messages -->
    <UI>
      <ProgressText Action="InstallServices">Registering Flight Hub service...</ProgressText>
      <ProgressText Action="StartServices">Starting Flight Hub service...</ProgressText>
    </UI>

    <!-- ========================================
         ICON
         ======================================== -->

    <Icon Id="FlightHubIcon.exe" SourceFile="$(var.BinDir)\flightd.exe" />

    <!-- ========================================
         DIRECTORY STRUCTURE
         ======================================== -->

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Flight Hub">
          <Directory Id="BinFolder" Name="bin" />
          <Directory Id="ConfigFolder" Name="config" />
          <Directory Id="LogsFolder" Name="logs" />
        </Directory>
      </Directory>

      <!-- Start Menu shortcuts -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="FlightHubMenuFolder" Name="Flight Hub" />
      </Directory>
    </Directory>

    <!-- ========================================
         FEATURES
         ======================================== -->

    <!-- Core Feature - Required, cannot be deselected (Level 1) -->
    <Feature Id="Core"
             Title="Flight Hub Core"
             Description="Core Flight Hub daemon (flightd) and configuration files. This feature is required."
             Level="1"
             Absent="disallow"
             AllowAdvertise="no"
             Display="expand"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentGroupRef Id="CoreBinaries" />
      <ComponentGroupRef Id="CoreConfig" />
      <ComponentGroupRef Id="CoreRegistry" />
      <ComponentRef Id="FlightHubMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- CLI Tools Feature - Optional, default selected (Level 2) -->
    <Feature Id="CLI"
             Title="Command Line Tools"
             Description="Flight Hub command-line interface (flightctl). Provides CLI access for configuration, diagnostics, and automation."
             Level="2"
             AllowAdvertise="no">
      <ComponentGroupRef Id="CLIBinaries" />
      <ComponentRef Id="CLIMenuShortcut" />
    </Feature>

    <!-- PATH Environment Variable - Optional feature -->
    <Feature Id="PathEnv"
             Title="Add to PATH"
             Description="Add Flight Hub bin directory to the system PATH environment variable for easy command-line access."
             Level="2"
             AllowAdvertise="no">
      <ComponentRef Id="PathEnvVar" />
    </Feature>

    <!-- ========================================
         SERVICE INSTALLATION
         ======================================== -->

    <!-- Windows Service for flightd -->
    <ComponentGroup Id="ServiceComponents">
      <Component Id="FlightdService" Guid="1A2B3C4D-5E6F-7890-ABCD-EF1234567890" Directory="BinFolder">
        <File Id="flightd_exe_svc" Source="$(var.BinDir)\flightd.exe" KeyPath="yes" />
        <ServiceInstall Id="FlightdServiceInstall"
                        Type="ownProcess"
                        Name="FlightHub"
                        DisplayName="Flight Hub Service"
                        Description="Flight Hub input management service for flight simulation"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal">
          <!-- Service recovery options -->
          <util:ServiceConfig FirstFailureActionType="restart"
                              SecondFailureActionType="restart"
                              ThirdFailureActionType="none"
                              RestartServiceDelayInSeconds="60"
                              ResetPeriodInDays="1" />
        </ServiceInstall>
        <ServiceControl Id="FlightdServiceControl"
                        Name="FlightHub"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>

  </Product>
</Wix>
