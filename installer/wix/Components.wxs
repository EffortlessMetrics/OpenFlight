<?xml version="1.0" encoding="UTF-8"?>
<!--
  Flight Hub Windows Installer - Component Definitions (WiX 3.x)

  This file defines all components for the Flight Hub installer:
  - CoreBinaries: Main daemon binary (flightd.exe)
  - CLIBinaries: CLI tool (flightctl.exe)
  - CoreConfig: Configuration directory structure
  - CoreRegistry: Windows service registration and registry entries
  - Shortcuts: Start Menu and Desktop shortcuts
  - PathEnvVar: Optional PATH environment variable addition

  Requirements:
  - WiX Toolset 3.x
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <!-- ========================================
       CORE BINARIES
       Main Flight Hub daemon executable
       ======================================== -->

  <Fragment>
    <ComponentGroup Id="CoreBinaries" Directory="BinFolder">

      <!-- Flight Hub Service Daemon -->
      <Component Id="flightd_exe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="flightd_exe"
              Name="flightd.exe"
              Source="$(var.BinDir)\flightd.exe"
              KeyPath="yes"
              Vital="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ========================================
       CLI BINARIES
       Command-line interface executable
       ======================================== -->

  <Fragment>
    <ComponentGroup Id="CLIBinaries" Directory="BinFolder">

      <!-- Flight Hub CLI Tool -->
      <Component Id="flightctl_exe" Guid="B2C3D4E5-F6A7-8901-BCDE-F23456789012">
        <File Id="flightctl_exe"
              Name="flightctl.exe"
              Source="$(var.BinDir)\flightctl.exe"
              KeyPath="yes"
              Vital="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ========================================
       CORE CONFIGURATION
       Configuration directory and default files
       ======================================== -->

  <Fragment>
    <ComponentGroup Id="CoreConfig" Directory="ConfigFolder">

      <!-- Default configuration file -->
      <Component Id="DefaultConfig" Guid="D4E5F6A7-B8C9-0123-DEF0-456789012345">
        <File Id="config_toml"
              Name="config.toml"
              Source="$(var.ConfigDir)\config.toml"
              KeyPath="yes" />
      </Component>

      <!-- Default profile template -->
      <Component Id="DefaultProfile" Guid="E5F6A7B8-C9D0-1234-EF01-567890123456">
        <File Id="default_profile_toml"
              Name="default.profile.toml"
              Source="$(var.ConfigDir)\default.profile.toml"
              KeyPath="yes" />
      </Component>

      <!-- Create empty logs directory -->
      <Component Id="LogsDirectory" Guid="F6A7B8C9-D0E1-2345-F012-678901234567" Directory="LogsFolder">
        <CreateFolder />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ========================================
       CORE REGISTRY
       Windows service registration and app registry entries
       ======================================== -->

  <Fragment>
    <ComponentGroup Id="CoreRegistry" Directory="INSTALLFOLDER">

      <!-- Application registry entries -->
      <Component Id="AppRegistryEntries" Guid="C3D4E5F6-A7B8-9012-CDEF-345678901234">
        <RegistryKey Root="HKLM" Key="SOFTWARE\OpenFlight\Flight Hub">
          <RegistryValue Type="string" Name="InstallPath" Value="[INSTALLFOLDER]" KeyPath="yes" />
          <RegistryValue Type="string" Name="Version" Value="[ProductVersion]" />
          <RegistryValue Type="string" Name="BinPath" Value="[BinFolder]" />
          <RegistryValue Type="string" Name="ConfigPath" Value="[ConfigFolder]" />
        </RegistryKey>
      </Component>

      <!-- Windows Service registration via registry -->
      <!-- Note: ServiceInstall in Product.wxs handles primary service registration -->
      <!-- These entries provide additional configuration -->
      <Component Id="ServiceRegistryEntries" Guid="2B3C4D5E-6F7A-8901-CDEF-456789012345">
        <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\FlightHub">
          <RegistryValue Type="expandString" Name="ImagePath" Value="&quot;[BinFolder]flightd.exe&quot; --service" KeyPath="yes" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\FlightHub\Parameters">
          <RegistryValue Type="string" Name="ConfigPath" Value="[ConfigFolder]config.toml" />
          <RegistryValue Type="string" Name="LogPath" Value="[LogsFolder]" />
        </RegistryKey>
      </Component>

      <!-- Event Log registration for flightd service -->
      <Component Id="EventLogRegistration" Guid="3C4D5E6F-7A8B-9012-DEF0-567890123456">
        <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\EventLog\Application\FlightHub">
          <RegistryValue Type="expandString" Name="EventMessageFile" Value="[BinFolder]flightd.exe" KeyPath="yes" />
          <RegistryValue Type="integer" Name="TypesSupported" Value="7" />
        </RegistryKey>
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ========================================
       PATH ENVIRONMENT VARIABLE
       Optional addition to system PATH
       ======================================== -->

  <Fragment>
    <Component Id="PathEnvVar" Guid="4D5E6F7A-8B9C-0123-EF01-678901234567" Directory="INSTALLFOLDER">
      <Environment Id="PATH"
                   Name="PATH"
                   Value="[BinFolder]"
                   Permanent="no"
                   Part="last"
                   Action="set"
                   System="yes" />
      <CreateFolder />
    </Component>
  </Fragment>

  <!-- ========================================
       START MENU SHORTCUTS
       ======================================== -->

  <Fragment>
    <!-- Main Flight Hub shortcut (for Core feature) -->
    <Component Id="FlightHubMenuShortcut" Guid="5E6F7A8B-9C0D-1234-F012-789012345678" Directory="FlightHubMenuFolder">
      <Shortcut Id="FlightHubStartMenuShortcut"
                Name="Flight Hub"
                Description="Flight Hub - Flight Simulation Input Management"
                Target="[BinFolder]flightd.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="FlightHubIcon.exe" />
      <RemoveFolder Id="RemoveFlightHubMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\OpenFlight\Flight Hub" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- CLI shortcut (for CLI feature) -->
    <Component Id="CLIMenuShortcut" Guid="6F7A8B9C-0D1E-2345-0123-890123456789" Directory="FlightHubMenuFolder">
      <Shortcut Id="FlightctlStartMenuShortcut"
                Name="Flight Hub CLI"
                Description="Flight Hub Command Line Interface"
                Target="[BinFolder]flightctl.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\OpenFlight\Flight Hub" Name="CLIShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

  <!-- ========================================
       DESKTOP SHORTCUT
       ======================================== -->

  <Fragment>
    <DirectoryRef Id="TARGETDIR">
      <Directory Id="DesktopFolder" Name="Desktop" />
    </DirectoryRef>

    <Component Id="DesktopShortcut" Guid="7A8B9C0D-1E2F-3456-1234-901234567890" Directory="DesktopFolder">
      <Shortcut Id="FlightHubDesktopShortcut"
                Name="Flight Hub"
                Description="Flight Hub - Flight Simulation Input Management"
                Target="[BinFolder]flightd.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="FlightHubIcon.exe" />
      <RegistryValue Root="HKCU" Key="Software\OpenFlight\Flight Hub" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
