{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spec Ledger Schema",
  "description": "Schema for specs/spec_ledger.yaml - maps requirements to acceptance criteria and tests",
  "type": "object",
  "required": ["requirements"],
  "additionalProperties": false,
  "properties": {
    "requirements": {
      "type": "array",
      "description": "List of all product and infrastructure requirements",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "ac"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique requirement identifier",
            "pattern": "^(REQ|INF-REQ)-[0-9]+$"
          },
          "name": {
            "type": "string",
            "description": "Human-readable requirement name",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "description": "Optional requirement kind for filtering",
            "enum": ["product", "infra"]
          },
          "status": {
            "type": "string",
            "description": "Current implementation status of the requirement",
            "enum": ["draft", "implemented", "tested", "deprecated"]
          },
          "ac": {
            "type": "array",
            "description": "Acceptance criteria for this requirement",
            "items": {
              "type": "object",
              "required": ["id", "description"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Unique acceptance criteria identifier",
                  "pattern": "^AC-[0-9]+\\.[0-9]+$"
                },
                "description": {
                  "type": "string",
                  "description": "Human-readable acceptance criteria description",
                  "minLength": 1
                },
                "tests": {
                  "type": "array",
                  "description": "Test references validating this acceptance criteria",
                  "items": {
                    "oneOf": [
                      {
                        "type": "string",
                        "description": "Simple test path format: crate::module::test_name",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "description": "Detailed test reference with at least one field",
                        "minProperties": 1,
                        "additionalProperties": false,
                        "properties": {
                          "test": {
                            "type": "string",
                            "description": "Test path in crate::module::test_name format"
                          },
                          "feature": {
                            "type": "string",
                            "description": "Gherkin feature file reference"
                          },
                          "command": {
                            "type": "string",
                            "description": "Command to run for validation (e.g., cargo bench)"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
